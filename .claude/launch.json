{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Web (Opstap)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": [
        "run",
        "-d",
        "web-server",
        "--web-port",
        "8080",
        "--web-hostname",
        "localhost"
      ],
      "port": 8080
    },
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": [
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "port": 8000
    }
  ]
}
